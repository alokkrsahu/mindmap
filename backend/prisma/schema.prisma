generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  uploadedFileIds String[]
  messages        Message[]
  graphs          Graph[]
}

model Message {
  id         String   @id @default(cuid())
  role       String
  content    String
  toolCallId String?
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id])
  sessionId  String
}

model Graph {
  id           String   @id @default(cuid())
  nodes        Json
  edges        Json
  summary      String
  parentNodeId String?
  createdAt    DateTime @default(now())
  session      Session  @relation(fields: [sessionId], references: [id])
  sessionId    String
}
